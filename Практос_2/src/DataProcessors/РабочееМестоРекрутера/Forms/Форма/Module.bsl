	ЗаполнениеТЗ()
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаКандидатовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
			// Получаем данные текущей строки
 		   ТекущаяСтрокаДанных = Элемент.ДанныеСтроки(ВыбраннаяСтрока);    
   		 // Проверяем, что строка не пустая
  		 Если ТекущаяСтрокаДанных <> Неопределено Тогда
        
        // Пытаемся открыть ссылку из колонки "Ссылка"
        // (убедитесь, что имя колонки в Элементах формы именно "Ссылка")
        Если ЗначениеЗаполнено(ТекущаяСтрокаДанных.Ссылка) Тогда
            
            // Стандартная команда 1С: открыть форму объекта по ссылке
            ОткрытьЗначение(ТекущаяСтрокаДанных.Ссылка);
            
            // Отключаем стандартную обработку, так как мы сами открыли форму
            СтандартнаяОбработка = Ложь;
            
        КонецЕсли;
        
    КонецЕсли;
КонецПроцедуры

