
&НаКлиенте
Процедура ПриОткрытии(Отказ) 
Объект.Открыта = истина;
Объект.ПоискСотрудника = истина;
Объект.ВОжидании = истина;
Объект.Отменена = истина; 
Объект.Закрыта = истина;
ЗаполнениеТЗ();
КонецПроцедуры  

&НаСервере
Процедура ЗаполнениеТЗ()
МассивСтатусов = Новый Массив;
Если Объект.Открыта = Истина тогда
    МассивСтатусов.Добавить(Перечисления.СтатусОпубликованнойВакансии.Открыта);
КонецЕсли;
Если Объект.ПоискСотрудника = Истина тогда
	МассивСтатусов.Добавить(Перечисления.СтатусОпубликованнойВакансии.ПоискСотрудника);
КонецЕсли;
Если Объект.Отменена = Истина тогда
	МассивСтатусов.Добавить(Перечисления.СтатусОпубликованнойВакансии.Отменена); 
КонецЕсли;
Если Объект.ВОжидании = Истина тогда
    МассивСтатусов.Добавить(Перечисления.СтатусОпубликованнойВакансии.ВОжидании);
КонецЕсли;
Если Объект.Закрыта = Истина тогда
    МассивСтатусов.Добавить(Перечисления.СтатусОпубликованнойВакансии.Закрыта);
КонецЕсли;

ВыбранныйСотрудник = Объект.Сотрудник;
НужноФильтроватьПоСотруднику = ЗначениеЗаполнено(ВыбранныйСотрудник);

	Запрос = Новый Запрос;
Запрос.Текст = 
    "ВЫБРАТЬ
    |	ПубликацияВакансии.Вакансия КАК Вакансия,
    |	ПубликацияВакансии.Дата КАК Дата,
    |	ПубликацияВакансии.Ответственный КАК Ответственный,
    |	ПубликацияВакансии.ДатаНачалаРазмещения КАК ДатаНачалаРазмещения,
    |	ПубликацияВакансии.ДатаОкончанияРазмещения КАК ДатаОкончанияРазмещения,
    |	ПубликацияВакансии.Статус КАК Статус,
    |	ПубликацияВакансии.Ссылка КАК Ссылка,
    |	ПубликацияВакансии.Организация КАК Организация
    |ИЗ
    |	Документ.ПубликацияВакансии КАК ПубликацияВакансии
    |ГДЕ 
	|	(ПубликацияВакансии.Ответственный = &Сотрудник ИЛИ &ВыбранныйСотрудник = ЛОЖЬ)
    |	И ПубликацияВакансии.Статус В (&СписокСтатусов)"; 

Запрос.УстановитьПараметр("СписокСтатусов", МассивСтатусов);	    

Запрос.УстановитьПараметр("Сотрудник", ВыбранныйСотрудник);
Запрос.УстановитьПараметр("ВыбранныйСотрудник", НужноФильтроватьПоСотруднику);

РезультатЗапроса = Запрос.Выполнить();
Результат = РезультатЗапроса.Выгрузить();
ТаблицаКандидатов.Загрузить(РезультатЗапроса.Выгрузить());	

КонецПроцедуры

&НаКлиенте
