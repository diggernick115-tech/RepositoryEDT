&НаСервере
Процедура ОпределитьтекущегоСотрудникаНаСервере()  
	// 1. Получаем имя пользователя из системы 1С
    ИмяПользователяСистемы = ИмяПользователя();
    
    // 2. Ищем элемент в справочнике "Рекрутеры" (замените на ваш справочник)
    // Метод НайтиПоНаименованию ищет по полю "Наименование"
    НайденныйСотрудник = Справочники.Сотрудники.НайтиПоНаименованию(ИмяПользователяСистемы);
    
    // 3. Возвращаем найденную ссылку
	//Возврат НайденныйСотрудник;
	//ПолучитьИмяПользователя();// Выбрать текущего юзера, обновить форму 
	
	 НайтиРекрутераПоРеквизиту(ИмяПользователяСистемы);
	 Объект.Сотрудник = НайтиРекрутераПоРеквизиту(ИмяПользователяСистемы);
	 ЗаполнениеТЗ();
КонецПроцедуры   


&НаСервере
Функция НайтиРекрутераПоРеквизиту(ИмяПользователяСистемы)  
	
	Запрос = Новый Запрос;
    Запрос.Текст =  
	"ВЫБРАТЬ
	|Сотрудники.Ссылка КАК Ссылка,
	|Сотрудники.УчетнаяЗапись КАК УчетнаяЗапись
	|ИЗ
	|Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|Сотрудники.УчетнаяЗапись = &ИмяПользователяСистемы";
	
    
    Запрос.УстановитьПараметр("ИмяПользователяСистемы", ИмяПользователяСистемы);
    
    РезультатЗапроса = Запрос.Выполнить();
	//Результат = РезультатЗапроса.Выгрузить();
    
    Если Не РезультатЗапроса.Пустой() Тогда
        Выборка = РезультатЗапроса.Выбрать();
        Выборка.Следующий();
        Возврат Выборка.Ссылка; // Возвращаем найденную ссылку
    Иначе
        Возврат Справочники.Сотрудники.ПустаяСсылка(); // Если не нашли
    КонецЕсли;
	
КонецФункции

